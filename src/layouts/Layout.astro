---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro'

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Diego Cáceres — Software Engineer',
  description = 'Software Engineer uruguayo con más de 10 años construyendo para la web. Especialista en React, TypeScript y arquitecturas frontend y backend. Basado en Montevideo, Uruguay.',
} = Astro.props;

const siteUrl = 'https://diegocaceres.dev';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Diego Cáceres',
  url: siteUrl,
  email: 'hola@diegocaceres.dev',
  jobTitle: 'Software Engineer',
  description,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Montevideo',
    addressCountry: 'UY',
  },
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'ORT Uruguay',
  },
  sameAs: [
    'https://github.com/diegocaceres',
    'https://linkedin.com/in/diegocaceres',
  ],
};
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Primary -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Diego Cáceres" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_UY" />
    <meta property="og:site_name" content="Diego Cáceres" />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Diego Cáceres — Software Engineer" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&display=swap"
      rel="stylesheet"
    />

    <!-- Dark mode init — must run before paint to avoid flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (stored === 'dark' || (!stored && prefersDark)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
    <Analytics />
  </head>
  <body class="min-h-screen" style="background-color: var(--color-bg); color: var(--color-text);">
    <slot />
  </body>
</html>
